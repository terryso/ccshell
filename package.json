{
  "name": "ccshell",
  "version": "0.1.7",
  "description": "自然语言macOS shell命令接口 - Natural language macOS shell command interface",
  "main": "index.js",
  "bin": {
    "ccshell": "./index.js"
  },
  "scripts": {
    "test": "DEBUG= NODE_NO_WARNINGS=1 node --test test/*.test.js",
    "test:coverage": "bash scripts/test-coverage-fixed.sh",
    "test:watch": "DEBUG= NODE_NO_WARNINGS=1 node --test --watch test/*.test.js",
    "test:unit": "DEBUG= NODE_NO_WARNINGS=1 node --test test/index.test.js",
    "test:unit-coverage": "DEBUG= NODE_NO_WARNINGS=1 node --test --experimental-test-coverage test/index.test.js",
    "test:integration": "DEBUG= NODE_NO_WARNINGS=1 node --test test/integration.test.js",
    "test:clean": "node scripts/test-clean.js",
    "test:unit-only": "node scripts/test-unit-only.js",
    "test:quiet": "DEBUG= node --test --reporter=tap test/*.test.js 2>/dev/null | grep -E '^(not )?ok|^1\\.\\.|^# (PASS|FAIL)'",
    "lint": "echo \"No linting configured\" && exit 0",
    "prepack": "npm run lint && npm test",
    "prepublishOnly": "node scripts/pre-publish-check.js",
    "prepublish-check": "node scripts/pre-publish-check.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release": "node scripts/release.js",
    "ci": "npm ci && npm run lint && npm run test:coverage"
  },
  "files": [
    "index.js",
    "README.md",
    "README.zh.md",
    "LICENSE",
    "scripts/"
  ],
  "keywords": [
    "shell",
    "ai",
    "macos",
    "cli",
    "automation",
    "claude",
    "natural-language"
  ],
  "author": "Nick",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/terryso/ccshell.git"
  },
  "bugs": {
    "url": "https://github.com/terryso/ccshell/issues"
  },
  "homepage": "https://github.com/terryso/ccshell#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "coverage": {
    "threshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "tap": "^21.1.0",
    "tap-spec": "^5.0.0"
  }
}
